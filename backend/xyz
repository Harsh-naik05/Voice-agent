import express from "express";
import http from "http";
import { Server } from "socket.io";
import cors from "cors";
import fs from "fs";
import path from "path";
import { spawn } from "child_process";
import dotenv from "dotenv";
import { fileURLToPath } from "url";
import { GoogleGenerativeAI } from "@google/generative-ai";
import mongoose from "mongoose";

dotenv.config();

/* ---------------- MONGODB CONNECTION ---------------- */

mongoose.connect(process.env.MONGO_URI);

mongoose.connection.on("connected", () => {
  console.log("🟢 MongoDB connected");
});

mongoose.connection.on("error", (err) => {
  console.error("❌ MongoDB connection error:", err);
});

/* ---------------- SCHEMAS ---------------- */

const conversationSchema = new mongoose.Schema({
  userText: String,
  aiResponse: String,
  createdAt: { type: Date, default: Date.now }
});

const Conversation = mongoose.model("Conversation", conversationSchema);

const leadSchema = new mongoose.Schema({
  name: String,
  company: String,
  service: String,
  budget: String,
  status: { type: String, default: "Qualified" },
  createdAt: { type: Date, default: Date.now }
});

const Lead = mongoose.model("Lead", leadSchema);

/* ---------------- BASIC SETUP ---------------- */

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

const PYTHON_PATH = path.join(__dirname, ".venv", "Scripts", "python.exe");
console.log("🐍 Using Python:", PYTHON_PATH);

const app = express();
app.use(cors());

const server = http.createServer(app);

const io = new Server(server, {
  cors: {
    origin: "http://localhost:5173",
    methods: ["GET", "POST"],
  },
});

/* ---------------- GEMINI SETUP ---------------- */

const genAI = new GoogleGenerativeAI(process.env.GEMINI_API_KEY);

const model = genAI.getGenerativeModel({
  model: "gemini-2.5-flash",
});

/* ---------------- SOCKET ---------------- */

io.on("connection", (socket) => {

  console.log("✅ Client connected:", socket.id);

  let audioChunks = [];
  socket.llmBusy = false;

  socket.leadData = {
    name: "",
    company: "",
    service: "",
    budget: ""
  };

  socket.on("audio_chunk", (arrayBuffer) => {
    audioChunks.push(Buffer.from(arrayBuffer));
  });

  socket.on("audio_end", () => {

    console.log("🎙️ Audio recording finished");

    const audioBuffer = Buffer.concat(audioChunks);
    audioChunks = [];

    if (audioBuffer.length < 2000) return;

    const wavPath = path.join(
      __dirname,
      `recording-${socket.id}-${Date.now()}.wav`
    );

    const ffmpeg = spawn("ffmpeg", [
      "-hide_banner",
      "-loglevel", "error",
      "-y",
      "-i", "pipe:0",
      "-ar", "16000",
      "-ac", "1",
      "-acodec", "pcm_s16le",
      wavPath,
    ]);

    ffmpeg.stdin.write(audioBuffer);
    ffmpeg.stdin.end();

    ffmpeg.on("close", async () => {

      const stt = spawn(PYTHON_PATH, ["stt_stream.py", wavPath]);

      stt.stdout.on("data", async (data) => {

        const textChunk = data.toString().trim();
        if (!textChunk || textChunk === "STT started") return;

        console.log("📝 STT chunk:", textChunk);
        socket.emit("stt_chunk", textChunk);

        /* -------- LEAD EXTRACTION -------- */

        const lower = textChunk.toLowerCase();

        if (lower.includes("name is")) {
          socket.leadData.name = textChunk.split("is")[1]?.trim();
        }

        if (lower.includes("work at") || lower.includes("work for")) {
          socket.leadData.company = textChunk.replace(/i work (at|for)/i, "").trim();
        }

        if (lower.includes("need") || lower.includes("looking for") || lower.includes("interested")) {
          socket.leadData.service = textChunk;
        }

        if (lower.includes("budget") || lower.includes("$") || lower.includes("dollar")) {
          socket.leadData.budget = textChunk;
        }

        if (socket.llmBusy) return;
        socket.llmBusy = true;

        try {

          const lead = socket.leadData;

          const prompt = `
          You are VoiceGate AI, a friendly sales assistant.

          Collect this information step by step:
          1. Name
          2. Company
          3. Service
          4. Budget

          Collected so far:
          Name: ${lead.name || "missing"}
          Company: ${lead.company || "missing"}
          Service: ${lead.service || "missing"}
          Budget: ${lead.budget || "missing"}

          If everything is collected, thank the user and say our team will contact them.

          User message:
          ${textChunk}

          Reply in one short sentence.
          `;

          const result = await model.generateContent(prompt);

          let reply = result.response.text().trim();
          if (reply.length > 180) reply = reply.slice(0,180);

          console.log("🤖 Gemini:", reply);

          socket.emit("llm_response", reply);

          await Conversation.create({
            userText: textChunk,
            aiResponse: reply
          });

          /* -------- SAVE LEAD -------- */

          if (lead.name && lead.company && lead.service && lead.budget) {

            await Lead.create({
              name: lead.name,
              company: lead.company,
              service: lead.service,
              budget: lead.budget
            });

            console.log("✅ Lead saved:", lead);

            socket.emit("llm_response","Thank you! Our sales team will contact you soon.");

            // do NOT reset immediately or conversation restarts
          }

          /* -------- TTS -------- */

          const tts = spawn(PYTHON_PATH, ["tts.py", reply]);

          tts.stdout.on("data", (data) => {

            const audioFile = data.toString().trim();
            const audioPath = path.join(__dirname, audioFile);

            const audioBuffer = fs.readFileSync(audioPath);

            socket.emit("tts_audio", audioBuffer);

            fs.unlinkSync(audioPath);
          });

        } catch (err) {
          console.error("Gemini error:", err.message);
        }

        finally {
          socket.llmBusy = false;
        }

      });

      stt.on("close", () => {
        if (fs.existsSync(wavPath)) fs.unlinkSync(wavPath);
      });

    });

  });

});

/* ---------------- START SERVER ---------------- */

server.listen(3000, () => {
  console.log("🚀 Server running on http://localhost:3000");
});